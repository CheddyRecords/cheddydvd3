<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Cheddy Records</title>

<style>
html, body{
  margin:0;
  padding:0;
  width:100%;
  height:100%;
  overflow:hidden;
  display:flex;
  justify-content:center;
  align-items:center;
  background:#000;
}

#square-wrap{
  position:relative;
  width:min(100vw, 100vh);
  height:min(100vw, 100vh);
  overflow:hidden;

  background-image:url("background.jpg");
  background-size:cover;
  background-position:center;
  background-repeat:no-repeat;
}

canvas{
  position:absolute;
  top:0;
  left:0;
  width:100%;
  height:100%;
}
</style>
</head>

<body>

<div id="square-wrap">
  <canvas id="screen"></canvas>
</div>

<script>
const canvas = document.getElementById("screen");
const ctx = canvas.getContext("2d");
const wrap = document.getElementById("square-wrap");

function resize(){
  const size = wrap.clientWidth; // match square exactly
  canvas.width = size;
  canvas.height = size;
}

resize();
window.addEventListener("resize", resize);

const logo = new Image();
logo.src = "cheddy.png";

/* LOGO SIZE */
const SIZE = 220;

let x = 120;
let y = 100;

/* SPEED */
let dx = 4.2;
let dy = 3.8;

function animate(){

  ctx.clearRect(0,0,canvas.width,canvas.height);

  ctx.drawImage(logo,x,y,SIZE,SIZE);

  x += dx;
  y += dy;

  // BOUNDARY = square ONLY
  if(x <= 0 || x + SIZE >= canvas.width){
    dx = -dx;
  }

  if(y <= 0 || y + SIZE >= canvas.height){
    dy = -dy;
  }

  requestAnimationFrame(animate);
}

logo.onload = animate;

</script>

</body>
</html>
